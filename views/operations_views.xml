<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Maintenance Requests Tree View -->
    <record id="view_maintenance_tree" model="ir.ui.view">
        <name>assetflow.maintenance.tree</name>
        <model>assetflow.maintenance</model>
        <arch type="xml">
            <tree string="Maintenance Requests" decoration-danger="priority == 'high'" decoration-warning="state == 'pending'">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="priority"/>
                <field name="state" widget="badge"/>
            </tree>
        </arch>
    </record>

    <!-- Maintenance Form View with Workflow Buttons -->
    <record id="view_maintenance_form" model="ir.ui.view">
        <name>assetflow.maintenance.form</name>
        <model>assetflow.maintenance</model>
        <arch type="xml">
            <form string="Maintenance Request">
                <header>
                    <!-- Workflow Buttons -->
                    <button name="action_approve" string="Approve Repair" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'pending')]}"/>
                    <button name="action_resolve" string="Mark Resolved" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'approved')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,approved,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="priority"/>
                        </group>
                    </group>
                    <group string="Issue Details">
                        <field name="description" placeholder="Describe the damage or system failure here..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </arch>
    </record>

    <!-- Audit Cycle Form View with Sub-grid (Audit Lines) -->
    <record id="view_audit_form" model="ir.ui.view">
        <name>assetflow.audit.form</name>
        <model>assetflow.audit</model>
        <arch type="xml">
            <form string="Asset Audit Cycle">
                <header>
                    <button name="action_start_audit" string="Start Audit" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_close_audit" string="Lock &amp; Close Audit" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'open')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Q3 Electronics Verification"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_date"/>
                        </group>
                        <group>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group string="Assigned Auditors">
                        <field name="auditor_ids" widget="many2many_tags" placeholder="Select staff..."/>
                    </group>
                    <notebook>
                        <page string="Verification Grid">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="asset_id"/>
                                    <field name="verification_result" widget="badge"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Actions for Operations -->
    <record id="action_maintenance_request" model="ir.actions.act_window">
        <name>Maintenance Requests</name>
        <res_model>assetflow.maintenance</res_model>
        <view_mode>tree,form</view_mode>
    </record>

    <record id="action_asset_audit" model="ir.actions.act_window">
        <name>Audit Cycles</name>
        <res_model>assetflow.audit</res_model>
        <view_mode>tree,form</view_mode>
    </record>

    <!-- Menu Links -->
    <menuitem id="menu_maintenance_action" name="Maintenance Log" parent="menu_assetflow_operations" action="action_maintenance_request" sequence="10"/>
    <menuitem id="menu_audit_action" name="Audit Cycles" parent="menu_assetflow_operations" action="action_asset_audit" sequence="20"/>
</odoo>
